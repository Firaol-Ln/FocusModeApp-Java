<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:padding="24dp">

    <!-- Top Toggle -->
    <LinearLayout
        android:id="@+id/toggleContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:background="@drawable/tab_container_bg"
        android:padding="4dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tabStopwatch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            android:text="@string/stopwatch"
            android:textColor="@color/text_secondary"
            android:clickable="true"
            android:focusable="true"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tabTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/tab_bg_selected"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            android:text="@string/timer"
            android:textColor="@color/text_primary"
            android:clickable="true"
            android:focusable="true"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Timer Label -->
    <LinearLayout
        android:id="@+id/timerLabelLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/toggleContainer"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:id="@+id/timerIndicator"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@android:color/holo_green_light"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/timerLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Timer >"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Clock Cards -->
    <LinearLayout
        android:id="@+id/clockContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomControls"
        android:layout_below="@id/timerLabelLayout"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Minutes Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMinutes"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="32dp"
            app:cardPreventCornerOverlap="false"
            app:cardUseCompatPadding="false"
            app:strokeWidth="0dp">

            <FrameLayout
                android:id="@+id/flMinutesCardRoot"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- 1. Top Next (Background) -->
                <FrameLayout
                    android:id="@+id/flMinutesTopNextContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipChildren="true">
                    <TextView
                        android:id="@+id/tvMinutesTopNext"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="25"
                        android:textColor="@color/text_primary"
                        android:textSize="180sp"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />
                </FrameLayout>

                <!-- 2. Bottom Current (Static) -->
                <FrameLayout
                    android:id="@+id/flMinutesBottomContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipChildren="true">
                    <TextView
                        android:id="@+id/tvMinutesBottom"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="25"
                        android:textColor="@color/text_primary"
                        android:textSize="180sp"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />
                </FrameLayout>

                <!-- 3. The Flap (Animated) -->
                <FrameLayout
                    android:id="@+id/flMinutesFlip"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipChildren="true"
                    android:visibility="invisible">
                    <TextView
                        android:id="@+id/tvMinutesFlip"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="25"
                        android:textColor="@color/text_primary"
                        android:textSize="180sp"
                        android:textStyle="bold"
                        android:includeFontPadding="false"
                        android:background="@color/card_bg" />

                    <View
                        android:id="@+id/vMinutesFlipShadow"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:alpha="0"
                        android:background="#AA000000" />
                </FrameLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_gravity="center"
                    android:background="@color/screen_bg"
                    android:elevation="4dp" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Seconds Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSeconds"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="32dp"
            app:cardPreventCornerOverlap="false"
            app:cardUseCompatPadding="false"
            app:strokeWidth="0dp">

            <FrameLayout
                android:id="@+id/flSecondsCardRoot"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- 1. Top Next -->
                <FrameLayout
                    android:id="@+id/flSecondsTopNextContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipChildren="true">
                    <TextView
                        android:id="@+id/tvSecondsTopNext"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="00"
                        android:textColor="@color/text_primary"
                        android:textSize="180sp"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />
                </FrameLayout>

                <!-- 2. Bottom Current -->
                <FrameLayout
                    android:id="@+id/flSecondsBottomContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipChildren="true">
                    <TextView
                        android:id="@+id/tvSecondsBottom"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="00"
                        android:textColor="@color/text_primary"
                        android:textSize="180sp"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />
                </FrameLayout>

                <!-- 3. The Flap -->
                <FrameLayout
                    android:id="@+id/flSecondsFlip"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipChildren="true"
                    android:visibility="invisible">
                    <TextView
                        android:id="@+id/tvSecondsFlip"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="00"
                        android:textColor="@color/text_primary"
                        android:textSize="180sp"
                        android:textStyle="bold"
                        android:includeFontPadding="false"
                        android:background="@color/card_bg" />

                    <View
                        android:id="@+id/vSecondsFlipShadow"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#AA000000"
                        android:alpha="0" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvMilliseconds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="16dp"
                    android:text="00"
                    android:textColor="@color/text_secondary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_gravity="center"
                    android:background="@color/screen_bg"
                    android:elevation="4dp" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Bottom Controls -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="center"
        android:paddingBottom="16dp"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnCategories"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/timer_card_bg"
            android:src="@drawable/ic_settings"
            android:padding="16dp"
            app:tint="@color/icon_tint"
            android:scaleType="fitCenter"
            android:contentDescription="Settings" />

        <View
            android:layout_width="40dp"
            android:layout_height="0dp" />

        <ImageButton
            android:id="@+id/btnStart"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/timer_card_bg"
            android:src="@drawable/ic_play"
            android:padding="20dp"
            app:tint="@color/icon_tint"
            android:scaleType="fitCenter"
            android:contentDescription="Start" />

        <View
            android:layout_width="40dp"
            android:layout_height="0dp" />

        <ImageButton
            android:id="@+id/btnStats"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/timer_card_bg"
            android:src="@drawable/ic_stats"
            android:padding="16dp"
            app:tint="@color/icon_tint"
            android:scaleType="fitCenter"
            android:contentDescription="Stats" />

    </LinearLayout>

</RelativeLayout>
