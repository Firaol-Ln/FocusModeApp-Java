<resources>

    <!-- Screen Background -->
    <style name="AppBackground">
        <item name="android:background">@color/screen_bg</item>
        <item name="android:padding">24dp</item>
    </style>

    <!-- Timer Box -->
    <style name="TimerBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">300dp</item>
        <item name="android:background">@color/timer_box_bg</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">20dp</item>
    </style>

    <!-- Timer Text -->
    <style name="TimerText">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">72sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Primary Button -->
    <style name="PrimaryButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_on_accent</item>
        <item name="android:background">@color/accent_color</item>
        <item name="android:padding">12dp</item>
    </style>

    <!-- Secondary Button -->
    <style name="SecondaryButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:background">@color/secondary_button_bg</item>
        <item name="android:padding">12dp</item>
    </style>

</resources>